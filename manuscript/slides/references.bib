@article{tang2021,
  title = {On {{Identifiability}} and {{Consistency}} of {{The Nugget}} in {{Gaussian Spatial Process Models}}},
  author = {Tang, Wenpin and Zhang, Lu and Banerjee, Sudipto},
  year = {2021},
